{
  "order": 200,
  "kernelId": "hermes",
  "displayName": "Hermes Agent",
  "vendor": "Nous Research",
  "launcherKinds": ["externalWslOrRemote"],
  "platformSupport": {
    "windows": "wsl2OrRemoteOnly",
    "macos": "native",
    "linux": "native"
