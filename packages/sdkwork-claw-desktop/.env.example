# Desktop runtime environment.
VITE_APP_ENV="development"

# Backend API base URL used for desktop update checks.
# This is also the default base URL for the app SDK.
VITE_API_BASE_URL="https://api-dev.sdkwork.com"

# IM websocket endpoint used by the frontend IM runtime.
VITE_IM_WS_URL="wss://im-dev.sdkwork.com/ws"

# Optional bearer token used to authorize desktop update checks.
VITE_ACCESS_TOKEN=""

# Backend app id for POST /app/v3/api/update/check.
VITE_APP_ID="10001"

# Desktop release channel.
VITE_RELEASE_CHANNEL="stable"

# Desktop distribution manifest id.
VITE_DISTRIBUTION_ID="global"

# Force desktop mode when running the shell outside native Tauri.
VITE_PLATFORM="desktop"

# Shared HTTP timeout in milliseconds.
VITE_TIMEOUT="30000"

# Enable the startup update check in the desktop shell.
VITE_ENABLE_STARTUP_UPDATE_CHECK="true"

# Optional OpenClaw admin API override. Leave blank to resolve the built-in loopback
# endpoint from the desktop runtime automatically.
VITE_OPENCLAW_ADMIN_BASE_URL=""

# Optional OpenClaw gateway override. Leave blank to resolve the built-in loopback
# endpoint from the desktop runtime automatically.
VITE_OPENCLAW_GATEWAY_BASE_URL=""

# Optional bearer token for OpenClaw admin requests.
VITE_OPENCLAW_ADMIN_TOKEN=""

# Optional prebuilt OpenClaw runtime directory used by the desktop bundler.
OPENCLAW_BUNDLED_SOURCE_DIR=""

# Optional OpenClaw package tarball override used during bundled runtime preparation.
OPENCLAW_PACKAGE_TARBALL=""

# Force rebuilding the bundled OpenClaw runtime instead of reusing the prepared resource.
OPENCLAW_FORCE_PREPARE="false"

# Optional OpenClaw version overrides for controlled release builds.
OPENCLAW_VERSION="2026.3.28"
OPENCLAW_NODE_VERSION="22.16.0"
