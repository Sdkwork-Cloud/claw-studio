# Desktop runtime environment.
VITE_APP_ENV="development"

# Backend API base URL used for desktop update checks.
VITE_API_BASE_URL="http://localhost:8080"

# Optional bearer token used to authorize desktop update checks.
VITE_ACCESS_TOKEN=""

# Backend app id for POST /app/v3/api/update/check.
VITE_APP_ID="10001"

# Desktop release channel.
VITE_RELEASE_CHANNEL="stable"

# Desktop distribution manifest id.
VITE_DISTRIBUTION_ID="global"

# Force desktop mode when running the shell outside native Tauri.
VITE_PLATFORM="desktop"

# Shared HTTP timeout in milliseconds.
VITE_TIMEOUT="30000"

# Enable the startup update check in the desktop shell.
VITE_ENABLE_STARTUP_UPDATE_CHECK="true"

# Optional sdkwork-api-router admin base URL override. Leave blank to resolve the built-in host
# endpoint from the desktop runtime status, which defaults to http://127.0.0.1:12103/api/admin.
VITE_API_ROUTER_ADMIN_BASE_URL=""

# Optional sdkwork-api-router gateway base URL override. Leave blank to resolve the built-in host
# endpoint from the desktop runtime status, which defaults to http://127.0.0.1:12103/api.
VITE_API_ROUTER_GATEWAY_BASE_URL=""

# Optional bearer token for sdkwork-api-router admin requests.
VITE_API_ROUTER_ADMIN_TOKEN=""

# Optional prebuilt sdkwork-api-router runtime directory used by the desktop bundler.
SDKWORK_API_ROUTER_BUNDLED_SOURCE_DIR=""

# Optional sdkwork-api-router source workspace used when no prebuilt runtime directory is provided.
SDKWORK_API_ROUTER_SOURCE_REPO_DIR=""

# Force rebuilding the bundled sdkwork-api-router runtime instead of reusing the prepared resource.
SDKWORK_API_ROUTER_FORCE_PREPARE="false"

# Optional host-managed sdkwork-api-router base port. When set, gateway/admin/portal bind to
# 127.0.0.1:<base>, 127.0.0.1:<base+1>, and 127.0.0.1:<base+2>.
SDKWORK_API_ROUTER_BASE_PORT=""

# Optional explicit sdkwork-api-router bind overrides. These take precedence over the base port
# and any shared router config file values during managed startup and runtime inspection.
SDKWORK_API_ROUTER_GATEWAY_BIND=""
SDKWORK_API_ROUTER_ADMIN_BIND=""
SDKWORK_API_ROUTER_PORTAL_BIND=""

# Optional built-in web host bind override used to expose gateway/admin/portal through a single
# same-origin entrypoint and to serve the bundled admin/portal static sites.
SDKWORK_API_ROUTER_WEB_BIND=""

# Optional managed site toggles. By default, both admin and portal are enabled when the bundled
# sdkwork-api-router runtime starts.
SDKWORK_API_ROUTER_ENABLE_ADMIN="true"
SDKWORK_API_ROUTER_ENABLE_PORTAL="true"

# Optional static site directories for the built-in host. When left blank, Claw Studio resolves
# bundled admin/portal assets from the prepared sdkwork-api-router runtime when available.
SDKWORK_API_ROUTER_ADMIN_SITE_DIR=""
SDKWORK_API_ROUTER_PORTAL_SITE_DIR=""

# Legacy aliases still honored by the supervisor for external site bundle locations.
SDKWORK_ADMIN_SITE_DIR=""
SDKWORK_PORTAL_SITE_DIR=""
