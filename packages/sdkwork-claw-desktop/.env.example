# Desktop runtime environment.
VITE_APP_ENV="development"

# Backend API base URL used for desktop update checks.
VITE_API_BASE_URL="http://localhost:8080"

# Optional sdkwork-api-router admin base URL used by dashboard token analytics.
VITE_API_ROUTER_ADMIN_BASE_URL="http://localhost:8091"

# Optional bearer token used for sdkwork-api-router admin requests.
VITE_API_ROUTER_ADMIN_TOKEN=""

# Optional bearer token used to authorize desktop update checks.
VITE_ACCESS_TOKEN=""

# Backend app id for POST /app/v3/api/update/check.
VITE_APP_ID="10001"

# Desktop release channel.
VITE_RELEASE_CHANNEL="stable"

# Desktop distribution manifest id.
VITE_DISTRIBUTION_ID="global"

# Force desktop mode when running the shell outside native Tauri.
VITE_PLATFORM="desktop"

# Shared HTTP timeout in milliseconds.
VITE_TIMEOUT="30000"

# Enable the startup update check in the desktop shell.
VITE_ENABLE_STARTUP_UPDATE_CHECK="true"
