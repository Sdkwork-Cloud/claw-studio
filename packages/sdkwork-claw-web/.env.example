# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Shared backend API base URL for typed frontend infrastructure clients.
VITE_API_BASE_URL="http://localhost:8080"

# Optional sdkwork-api-router admin base URL used by dashboard token analytics.
VITE_API_ROUTER_ADMIN_BASE_URL="http://localhost:8091"

# Optional bearer token used for sdkwork-api-router admin requests.
VITE_API_ROUTER_ADMIN_TOKEN=""

# Optional access token for backend calls that require authentication.
VITE_ACCESS_TOKEN=""

# Backend app id reserved for desktop update checks.
VITE_APP_ID="10001"

# Release channel reserved for desktop update checks.
VITE_RELEASE_CHANNEL="stable"

# Optional sdkwork-api-router admin base URL override. In desktop mode you can usually leave this
# blank and let the runtime resolve the built-in host endpoint automatically.
VITE_API_ROUTER_ADMIN_BASE_URL=""

# Optional sdkwork-api-router gateway base URL override. In desktop mode you can usually leave
# this blank and let the runtime resolve the built-in host endpoint automatically.
VITE_API_ROUTER_GATEWAY_BASE_URL=""

# Optional bearer token for sdkwork-api-router admin requests.
VITE_API_ROUTER_ADMIN_TOKEN=""
