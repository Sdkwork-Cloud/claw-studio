{
  "name": "@sdkwork/claw-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node ../../scripts/run-vite-host.mjs serve --host 0.0.0.0 --port 3001 --mode development",
    "dev:test": "node ../../scripts/run-vite-host.mjs serve --host 0.0.0.0 --port 3001 --mode test",
    "build": "node ../../scripts/prepare-shared-sdk-packages.mjs && node ../../scripts/run-vite-host.mjs build --mode production",
    "build:dev": "node ../../scripts/prepare-shared-sdk-packages.mjs && node ../../scripts/run-vite-host.mjs build --mode development",
    "build:test": "node ../../scripts/prepare-shared-sdk-packages.mjs && node ../../scripts/run-vite-host.mjs build --mode test",
    "build:prod": "node ../../scripts/prepare-shared-sdk-packages.mjs && node ../../scripts/run-vite-host.mjs build --mode production",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "node ../../scripts/run-workspace-tsc.mjs --noEmit"
  },
  "dependencies": {
    "@sdkwork/claw-i18n": "workspace:*",
    "@sdkwork/claw-shell": "workspace:*",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.5.2",
    "@vitejs/plugin-react": "^6.0.1",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.2",
    "vite": "^8.0.3"
  },
  "exports": {
    ".": "./src/index.ts"
  }
}
