{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claw Studio",
  "version": "0.1.0",
  "identifier": "com.sdkwork.claw-studio",
  "build": {
    "beforeDevCommand": "pnpm run dev -- --host 127.0.0.1 --port 1420",
    "beforeBuildCommand": "pnpm run build",
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:1420"
  },
  "app": {
    "windows": [
      {
        "title": "Claw Studio",
        "width": 1440,
        "height": 900,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ]
  }
}
