# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Desktop app runtime environment.
VITE_APP_ENV="development"

# Shared backend API base URL used by desktop update checks and other typed clients.
VITE_API_BASE_URL="http://localhost:8080"

# Optional bearer token used for backend app update checks.
VITE_ACCESS_TOKEN=""

# Backend app id used by POST /app/v3/api/update/check.
VITE_APP_ID="10001"

# Desktop release channel used during update checks.
VITE_RELEASE_CHANNEL="stable"

# Distribution id consumed by the desktop shell and manifest layer.
VITE_DISTRIBUTION_ID="global"

# Runtime platform identifier.
VITE_PLATFORM="desktop"

# HTTP timeout for backend API requests in milliseconds.
VITE_TIMEOUT="30000"

# Toggle automatic startup update checks in the desktop shell.
VITE_ENABLE_STARTUP_UPDATE_CHECK="true"

# Optional OpenClaw admin API override used by provider-control surfaces.
# Leave blank to let the desktop host resolve the built-in loopback endpoint automatically.
VITE_OPENCLAW_ADMIN_BASE_URL=""

# Optional OpenClaw gateway override used by routed OpenAI-compatible `/v1` requests.
# Leave blank to let the desktop host resolve the built-in loopback endpoint automatically.
VITE_OPENCLAW_GATEWAY_BASE_URL=""

# Optional bearer token for OpenClaw admin requests.
VITE_OPENCLAW_ADMIN_TOKEN=""
